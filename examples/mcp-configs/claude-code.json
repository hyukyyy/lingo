{
  "$comment": [
    "Claude Code MCP server configuration for Lingo.",
    "",
    "Installation options:",
    "  Option A (project-level): Save this as .mcp.json in your project root",
    "  Option B (global):        Merge into ~/.claude/mcp.json",
    "",
    "Quick setup via CLI:",
    "  claude mcp add lingo -- npx @lingo/mcp-server",
    "",
    "Environment variables (all optional):",
    "  LINGO_GLOSSARY_PATH  Path to glossary JSON file (default: .lingo/glossary.json)",
    "  LINGO_ORG            Organization name (default: 'default')",
    "  LINGO_LOG_LEVEL      Log verbosity: debug|info|warn|error (default: 'info')"
  ],
  "mcpServers": {
    "lingo": {
      "command": "npx",
      "args": [
        "@lingo/mcp-server"
      ],
      "env": {
        "LINGO_GLOSSARY_PATH": ".lingo/glossary.json",
        "LINGO_ORG": "default"
      }
    }
  }
}
